---
import BlogPage from '../../blueprints/dentist/pages/blog.astro';
import { blogArchive } from '../data/blog';
import { footer } from '../data/footer';
import { blogHero } from '../data/hero';
import { navigation } from '../data/navigation';
import { seo } from '../data/seo';
import { appointmentCta, site } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BlogPage
  appointmentCta={appointmentCta}
  baseLayout={BaseLayout}
  blog={blogArchive}
  footer={footer}
  hero={blogHero}
  navigation={navigation}
  seo={seo.blog}
  site={site}
/>
