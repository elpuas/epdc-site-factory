---
import { site } from "../../data/site";

const serviceAreaSummary = site.serviceAreas.join(", ");
---

<header class="site-header">
  <div class="utility-bar">
    <p>Serving {serviceAreaSummary} with family and cosmetic dental care.</p>
    <a href={site.primaryCta.href}>{site.primaryCta.label}</a>
  </div>
  <div class="inner">
    <a class="brand" href="/">
      <span class="brand-name">{site.name}</span>
      <span class="brand-tagline">{site.tagline}</span>
    </a>

    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {site.navigation.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <a class="header-cta" href={site.primaryCta.href}>{site.primaryCta.label}</a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .utility-bar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.625rem 1.25rem;
    margin: 0 auto;
    max-width: 72rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .utility-bar p {
    margin: 0;
  }

  .utility-bar a {
    font-weight: 700;
    text-decoration: none;
  }

  .inner {
    margin: 0 auto;
    max-width: 72rem;
    padding: 1rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    justify-content: space-between;
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .brand-name {
    font-weight: 700;
    font-size: 1.05rem;
  }

  .brand-tagline {
    font-size: 0.9rem;
    color: var(--muted);
    max-width: 26rem;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-list a {
    text-decoration: none;
    color: inherit;
    font-weight: 500;
  }

  .nav-list a:hover,
  .nav-list a:focus-visible {
    text-decoration: underline;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: var(--accent);
    color: white;
    text-decoration: none;
    font-weight: 700;
  }

  @media (max-width: 48rem) {
    .utility-bar {
      display: none;
    }

    .inner {
      align-items: flex-start;
    }

    nav {
      width: 100%;
    }

    .header-cta {
      width: 100%;
    }
  }
</style>
