{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epdc-site-factory.local/planner/task-schema.json",
  "title": "EPDC Planner Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "planningSummary",
    "tasks"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "slug",
        "industry",
        "sourceSpecification"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "industry": {
          "type": "string",
          "minLength": 1
        },
        "sourceSpecification": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "planningSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primaryGoal",
        "scopeSummary",
        "constraints"
      ],
      "properties": {
        "primaryGoal": {
          "type": "string",
          "minLength": 1
        },
        "scopeSummary": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "category",
        "priority",
        "dependencies"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "frontend",
            "backend",
            "seo",
            "content",
            "qa"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
