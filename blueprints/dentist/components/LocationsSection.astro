---
import type { Location } from '../data/types';

interface Props {
  locations: Location[];
}

const { locations } = Astro.props;
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow">Locations</p>
    <h2>Visit information</h2>
  </div>
  <div class="card-grid">
    {locations.map((location) => (
      <article class="card">
        <h3>{location.label}</h3>
        <p>{location.addressLine1}</p>
        <p>{location.district}, {location.city}, {location.province}</p>
        <p><strong>Phone:</strong> {location.phone}</p>
        <p><strong>WhatsApp:</strong> {location.whatsapp}</p>
        <ul class="plain-list">
          {location.hours.map((entry) => (
            <li>{entry.days}: {entry.open} - {entry.close}</li>
          ))}
        </ul>
        <p>{location.mapLabel}</p>
        <p class="muted">{location.parkingNotes}</p>
      </article>
    ))}
  </div>
</section>
