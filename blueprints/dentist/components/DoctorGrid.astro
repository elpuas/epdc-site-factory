---
import type { DoctorSectionData } from '../types';

interface Props {
  section: DoctorSectionData;
}

const { section } = Astro.props;
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow">{section.eyebrow}</p>
    <h2>{section.title}</h2>
  </div>
  <div class="card-grid">
    {section.doctors.map((doctor) => (
      <article class="card">
        <img class="avatar" src={doctor.image.src} alt={doctor.image.alt} />
        <h3>{doctor.name}</h3>
        <p class="muted">{doctor.role}</p>
        <p>{doctor.bioShort}</p>
        <p><strong>{section.specialtiesLabel}:</strong> {doctor.specialties.join(', ')}</p>
        <p><strong>{section.credentialsLabel}:</strong> {doctor.credentials.join(', ')}</p>
      </article>
    ))}
  </div>
</section>
