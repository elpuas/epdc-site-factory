---
import type { Benefit } from '../data/types';

interface Props {
  benefits: Benefit[];
  title?: string;
}

const { benefits, title = 'Benefits and differentiators' } = Astro.props;
---

<section class="section">
  <div class="section-heading">
    <p class="eyebrow">Differentiators</p>
    <h2>{title}</h2>
  </div>
  <div class="card-grid">
    {benefits.map((benefit) => (
      <article class="card">
        <h3>{benefit.title}</h3>
        <p>{benefit.description}</p>
      </article>
    ))}
  </div>
</section>
