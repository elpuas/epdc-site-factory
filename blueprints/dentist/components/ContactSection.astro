---
import type { ContactSectionData } from '../types';

interface Props {
  section: ContactSectionData;
}

const { section } = Astro.props;
---

<section class="section section--split">
  <div>
    <p class="eyebrow">{section.eyebrow}</p>
    <h2>{section.title}</h2>
    <p>{section.description}</p>
  </div>

  <div class="stack">
    {section.methods.map((method) => (
      <article class="card compact-card">
        <h3>{method.title}</h3>
        <a href={method.href}>{method.value}</a>
      </article>
    ))}
    <article class="card compact-card">
      <h3>{section.appointmentCardTitle}</h3>
      <p>{section.appointmentNote}</p>
      <p class="muted">{section.formDisclaimer}</p>
    </article>
  </div>
</section>
