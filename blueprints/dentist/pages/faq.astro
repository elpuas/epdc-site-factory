---
import AppointmentCTA from '../components/AppointmentCTA.astro';
import FAQSection from '../components/FAQSection.astro';
import Hero from '../components/Hero.astro';
import DentistLayout from '../layouts/DentistLayout.astro';
import { appointmentCta } from '../data/contact';
import { faqs } from '../data/faq';
import { homeHero } from '../data/hero';
import { site } from '../data/site';
---

<DentistLayout title={`FAQ | ${site.meta.title}`} description="Generic FAQ page template for the dental Blueprint.">
  <Hero
    hero={{
      ...homeHero,
      eyebrow: 'FAQ template',
      title: 'Questions answered through data-driven sections',
      description: 'The FAQ page can support general, service, and contact questions without embedding clinic-specific wording in the template.',
    }}
  />
  <FAQSection items={faqs} title="General and treatment placeholders" />
  <AppointmentCTA cta={appointmentCta} />
</DentistLayout>
