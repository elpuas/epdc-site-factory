---
import AppointmentCTA from '../components/AppointmentCTA.astro';
import FAQSection from '../components/FAQSection.astro';
import Hero from '../components/Hero.astro';
import ServiceCards from '../components/ServiceCards.astro';
import DentistLayout from '../layouts/DentistLayout.astro';
import { appointmentCta } from '../data/contact';
import { faqs } from '../data/faq';
import { homeHero } from '../data/hero';
import { services } from '../data/services';
import { site } from '../data/site';
---

<DentistLayout title={`Services | ${site.meta.title}`} description="Generic service archive template for the dental Blueprint.">
  <Hero
    hero={{
      ...homeHero,
      eyebrow: 'Services template',
      title: 'Service archive driven by structured treatment data',
      description: 'This page validates how a dental site can route visitors into treatment-specific pages without owning business copy in the template.',
    }}
  />
  <ServiceCards services={services} title="All service templates" />
  <FAQSection items={faqs} title="Common service questions" />
  <AppointmentCTA cta={appointmentCta} />
</DentistLayout>
