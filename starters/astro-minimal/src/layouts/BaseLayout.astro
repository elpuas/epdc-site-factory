---
import '../styles/global.css';

interface Props {
  description?: string;
  lang?: string;
  title: string;
}

const { description = 'EPDC Astro starter project.', lang = 'en', title } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
